# SEC-01 defense-in-depth: Cloudflare Pages security headers.
# CSP notes:
#  - script-src includes https://accounts.google.com for the Google GSI login script (auth.ts).
#  - style-src needs 'unsafe-inline' because the app renders inline style="" attributes
#    inside HTML template literals throughout (place-card, schedule, place-detail, etc.).
#  - frame-src/connect-src allow the Google Identity Services iframe + token endpoint.
#  - img-src allows https:+data: because thumbnails come from R2/CDN/QR/Google avatars.
#  - object-src 'none', base-uri 'none', frame-ancestors 'none', no wildcards.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' https://accounts.google.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://accounts.google.com; frame-src https://accounts.google.com; object-src 'none'; base-uri 'none'; frame-ancestors 'none'
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
